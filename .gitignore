# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
.next/
out/

# Environment (NEVER commit secrets!)
.env
.env.local
.env.*.local
*.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Prisma
prisma/migrations/**/migration_lock.toml
*.db

# Coverage
coverage/
.nyc_output/

# Misc
*.tsbuildinfo
*.log
