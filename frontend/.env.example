# ReportOps Frontend — Environment Variables
# Copy to .env.local

# Backend API URL (for API proxy in development)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Frontend URL (used in shared UI text)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ONLYOFFICE Document Server URL (public, accessible from browser)
NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost:8080

# Benchmark labels shown in the UI
NEXT_PUBLIC_BENCHMARK_NAME=CIS AlmaLinux OS 9 Benchmark
NEXT_PUBLIC_BENCHMARK_VERSION=2.0.0
NEXT_PUBLIC_BENCHMARK_PROFILE=Level 1 - Server
