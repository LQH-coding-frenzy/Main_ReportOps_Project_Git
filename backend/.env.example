# ═══════════════════════════════════════════════════
# ReportOps Backend — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════

# ── Server ──
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Production should be: https://api.automatedprogram.app
BACKEND_PUBLIC_URL=http://localhost:4000

# ── Database (Supabase Postgres) ──
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# ── Supabase (for Storage) ──
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="reportops-documents"
SUPABASE_ARCHIVE_BUCKET="reportops-archives"

# ── GitHub OAuth App ──
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage URL: http://localhost:3000 (dev) or https://automatedprogram.app (prod)
# Callback URL: http://localhost:4000/api/auth/github/callback (dev)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:4000/api/auth/github/callback"

# ── GitHub API (for releases) ──
# Personal Access Token with 'repo' scope for creating/deleting report releases
GITHUB_TOKEN=""
GITHUB_REPO_OWNER="LQH-coding-frenzy"
GITHUB_REPO_NAME="Main_ReportOps_Project_Git"

# ── Project Metadata Source ──
# Optional absolute path to the repo-level project.answers.yaml
PROJECT_ANSWERS_PATH=""

# ── ONLYOFFICE Document Server ──
# Public URL (accessible from user's browser)
# Production should be: https://docs.automatedprogram.app
ONLYOFFICE_DOCUMENT_SERVER_URL="http://localhost:8080"
# Internal URL (for server-to-server, leave empty if same machine)
ONLYOFFICE_DOCUMENT_SERVER_INTERNAL_URL=""
ONLYOFFICE_JWT_SECRET="change-this-to-a-random-string"

# ── Preview Merge Worker ──
# Worker memory ceiling in MB for DOCX merge jobs
# Suggested: 1024 (2GB VM), 1536 (4-8GB VM)
REPORT_MERGE_WORKER_MAX_OLD_GENERATION_MB=1536

# ── Audit Runner (required in production for Lab VM automation) ──
AUDIT_RUNNER_SSH_KEY=""
AUDIT_RUNNER_SSH_PUBLIC_KEY=""

# ── JWT Auth ──
JWT_SECRET="change-this-to-a-random-32-char-string"
JWT_EXPIRES_IN="7d"
